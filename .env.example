# OpenWeather API Configuration
# Get your free API key at: https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_api_key_here

# Default Location (Happurg, Germany)
# You can change these coordinates to your preferred location
NEXT_PUBLIC_LOCATION_LAT=49.5181
NEXT_PUBLIC_LOCATION_LON=11.5167

# Optional: Set to 'production' for production builds
NODE_ENV=development
